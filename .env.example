# Copy to `.env` in this folder for docker compose variable substitution (optional).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gas_store

# Published ports
API_PORT=8000
WEB_PORT=8080
POSTGRES_PORT=5432

# Comma-separated browser origins allowed by FastAPI CORS
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
